{
	"name": "@roastery-capsules/post.post-tag",
	"description": "Post tag management capsule for the Roastery CMS ecosystem — CRUD operations with slug generation, pagination, and optional caching.",
	"version": "0.0.1",
	"author": {
		"name": "Alan Reis",
		"email": "alanreisanjo@gmail.com",
		"url": "https://github.com/Hoyasumii"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/roastery-cms/capsules.post_post-tag"
	},
	"license": "MIT",
	"keywords": [
		"roastery",
		"capsule",
		"cms",
		"post-tag",
		"tag-management",
		"slug",
		"elysia",
		"bun",
		"typescript",
		"prisma",
		"rest-api",
		"clean-architecture",
		"domain-driven-design"
	],
	"typesVersions": {
		"*": {
			"*": [
				"./dist/*/index.d.ts"
			]
		}
	},
	"exports": {
		"./*": {
			"types": "./dist/*/index.d.ts",
			"import": "./dist/*/index.js",
			"require": "./dist/*/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"type": "module",
	"scripts": {
		"build": "knip && biome check --fix && tsup 'src/**/index.ts' --format cjs,esm --dts --tsconfig tsconfig.build.json --clean",
		"test:unit": "bun test --env-file=.env.testing",
		"test:coverage": "bun test --env-file=.env.testing --coverage",
		"setup": "bun run build && bun link",
		"prepare": "husky || true",
		"knip": "knip"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.4.1",
		"@commitlint/config-conventional": "^20.4.1",
		"@elysiajs/eden": "^1.4.8",
		"@faker-js/faker": "^10.2.0",
		"husky": "^9.1.7",
		"knip": "^6.0.3"
	},
	"peerDependencies": {
		"@types/bun": "latest",
		"tsup": "^8.5.1",
		"typescript": "^5"
	},
	"dependencies": {
		"@roastery-adapters/cache": "^0.0.4",
		"@roastery-adapters/post": "^0.0.1",
		"@roastery-capsules/api-docs": "^0.0.3",
		"@roastery-capsules/api-error-handler": "^0.0.4",
		"@roastery-capsules/api-response-mapper": "^0.0.2",
		"@roastery-capsules/auth": "^0.0.1",
		"@roastery-capsules/env": "^0.0.4",
		"@roastery/barista": "^0.0.5",
		"@roastery/beans": "^0.0.2",
		"@roastery/seedbed": "^0.0.2",
		"@roastery/terroir": "^0.0.9"
	}
}
